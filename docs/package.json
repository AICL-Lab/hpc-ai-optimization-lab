{
  "name": "hpc-ai-optimization-lab-docs",
  "version": "0.3.0",
  "description": "Documentation site for HPC-AI-Optimization-Lab",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-changelog.mjs",
    "docs:dev": "npm run sync && vitepress dev .",
    "docs:build": "npm run sync && vitepress build .",
    "docs:preview": "vitepress preview .",
    "doxygen": "cd .. && doxygen docs/Doxyfile",
    "sphinx": "cd python && sphinx-build -b html . _build/html",
    "build:all": "npm run doxygen && npm run sphinx && npm run docs:build"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "vitepress": "^1.6.3",
    "vitepress-plugin-llms": "^1.10.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.4.21"
  },
  "dependencies": {
    "mermaid": "^11.12.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
